mcp.plusefin.com {
  tls /etc/caddy/certs/mcp.plusefin.com.crt /etc/caddy/certs/mcp.plusefin.com.key

  # Swagger / OpenAPI docs
  handle /docs* {
    reverse_proxy localhost:8002
  }
  handle /openapi.json {
    reverse_proxy localhost:8002
  }

  # HTTP API (new) - strip /api prefix
  handle /api/* {
    uri strip_prefix /api
    reverse_proxy localhost:8002
  }

  # MCP Server (existing)
  handle {
    reverse_proxy localhost:8001
  }
}

